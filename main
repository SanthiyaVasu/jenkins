node {

    stage('Clone Repo') {
        git branch: 'main',
            url: 'https://github.com/Akshara-PSG1/Streamlit_Temperature-Predictor.git'
    }

    stage('Install Dependencies') {
        powershell 'C:\\Users\\santh\\AppData\\Local\\Programs\\Python\\Python313\\python.exe -m venv venv'
        powershell '.\\venv\\Scripts\\python -m pip install -r requirements.txt'
    }

    stage('Run Streamlit App') {
        powershell 'Start-Process .\\venv\\Scripts\\python -ArgumentList "-m streamlit run streamlit_app.py --server.headless true --server.port 8501"'
    }
}
